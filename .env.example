DATABASE_URL=postgresql://agent:agent@postgres:5432/company_agent
RAG_API_PORT=8081
CRM_ADAPTER_PORT=8082
INTERNAL_API_KEY=change-me-before-production

# Embeddings (set to "openai" + key to enable semantic retrieval)
EMBEDDING_PROVIDER=disabled
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Generation models (used by OpenClaw agent + eval harness)
# Primary: Claude Haiku 4.5 — best Spanish persona consistency + handoff behavior
ANTHROPIC_API_KEY=
AGENT_MODEL_PRIMARY=claude-haiku-4-5-20251001
AGENT_MODEL_FALLBACK=claude-sonnet-4-6

# Optional alternative providers for eval comparison
GOOGLE_API_KEY=

# CRM provider: "mock" for local dev, "zoho" for sandbox/production
CRM_PROVIDER=mock

# Zoho CRM — Self Client OAuth
# Self Client setup: https://api-console.zoho.com  →  Add Client → Self Client
# Required scopes for v1:
#   ZohoCRM.modules.contacts.READ,ZohoCRM.modules.deals.READ,
#   ZohoCRM.modules.custom.ALL,ZohoCRM.modules.notes.CREATE,
#   ZohoCRM.coql.READ
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_DC=com
# Set to true to hit https://sandbox.zohoapis.<dc> instead of www.zohoapis.<dc>
ZOHO_SANDBOX=true

# Internal service URLs (private VPC in production)
RAG_API_URL=http://rag-api:8081
CRM_ADAPTER_URL=http://crm-adapter:8082
LOG_LEVEL=INFO
